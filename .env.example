# Exocort — copy to .env and adjust.

# -----------------------------------------------------------------------------
# Audio capture (exocort-audio)
# -----------------------------------------------------------------------------
# Microphone (input) — what you say
AUDIO_CAPTURE_ENABLED=1
AUDIO_CAPTURE_SPOOL_DIR=./tmp/audio
AUDIO_CAPTURE_REQUEST_TIMEOUT_S=30
AUDIO_CAPTURE_MAX_UPLOAD_PER_CYCLE=5
AUDIO_CAPTURE_MIN_RMS=0
AUDIO_CAPTURE_RECONNECT_DELAY_S=5
AUDIO_CAPTURE_SAMPLE_RATE=8000
AUDIO_CAPTURE_TARGET_SAMPLE_RATE=8000
AUDIO_CAPTURE_FRAME_MS=20
AUDIO_CAPTURE_VAD_MODE=2
AUDIO_CAPTURE_START_RMS=150
AUDIO_CAPTURE_CONTINUE_RMS=100
AUDIO_CAPTURE_START_TRIGGER_MS=120
AUDIO_CAPTURE_START_WINDOW_MS=400
AUDIO_CAPTURE_END_SILENCE_MS=700
AUDIO_CAPTURE_PRE_ROLL_MS=300
AUDIO_CAPTURE_MIN_SEGMENT_MS=500
AUDIO_CAPTURE_MAX_SEGMENT_MS=30000
AUDIO_CAPTURE_INPUT_DEVICE=
AUDIO_CAPTURE_LATENCY=
AUDIO_CAPTURE_GAIN_DB=0.0
AUDIO_CAPTURE_DIAGNOSTIC_S=0
AUDIO_CAPTURE_LOW_SPEECH_RATIO=0.2
AUDIO_CAPTURE_LOW_SPEECH_MAX_MS=1600

# -----------------------------------------------------------------------------
# Screen capture (exocort-screen)
# -----------------------------------------------------------------------------
SCREEN_CAPTURE_TMP_DIR=./tmp/screen
SCREEN_CAPTURE_ENABLED=1
SCREEN_CAPTURE_FPS=0.5
SCREEN_CAPTURE_REQUEST_TIMEOUT_S=30
SCREEN_CAPTURE_PROMPT_PERMISSION=1
SCREEN_CAPTURE_DEDUP_THRESHOLD=5 # Perceptual hash threshold for skipping consecutive frames. 0=identical, 5=minor changes.

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Collector (exocort-collector) — receives uploads, forwards per config.json
# Endpoints where capturers send audio/screen. Set to 0 to run only capture agents.
# -----------------------------------------------------------------------------
COLLECTOR_ENABLED=1
COLLECTOR_HOST=127.0.0.1
COLLECTOR_PORT=8000
COLLECTOR_AUDIO_URL=http://127.0.0.1:8000/api/audio
COLLECTOR_SCREEN_URL=http://127.0.0.1:8000/api/screen
COLLECTOR_CONFIG=./config/config.local.json
COLLECTOR_TMP_DIR=./tmp/collector
COLLECTOR_VAULT_DIR=./vault

# -----------------------------------------------------------------------------
# API keys (set the one used by your config: config.openai.json vs config.gemini.json)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Processor (exocort-processor) — layered memory from vault via LLM
# -----------------------------------------------------------------------------
PROCESSOR_ENABLED=1
PROCESSOR_VAULT_DIR=./vault
PROCESSOR_OUT_DIR=./vault/processed
PROCESSOR_STATE_DIR=./vault/processed/state
PROCESSOR_MAX_CONCURRENT_TASKS=1
PROCESSOR_L1_TRIGGER_THRESHOLD=1
PROCESSOR_L2_TRIGGER_THRESHOLD=10
PROCESSOR_L3_TRIGGER_THRESHOLD=20
PROCESSOR_L4_ENABLED=1
PROCESSOR_L4_INTERVAL_HOURS=24


# -----------------------------------------------------------------------------
# LLM Prompts
# -----------------------------------------------------------------------------
PROMPT_L1_CLEAN="You analyze a batch of raw vault records and convert each one into an activity trace. Return strict JSON only with a top-level key 'events'. The output array must contain exactly one item per input event in the same order. Each item must include only: l1_event_id, timestamp, title, description, meta. Goal: describe what the user is doing, looking at, reading, saying, hearing, or discussing. Put all relevant visible or spoken content inside description when it matters for understanding the activity. Do not create a second field that repeats the same information in other words. Do not extract verbatim quotes. title should be short and specific. description should be concise but information-dense: include the action, the topic, and the most relevant on-screen or spoken content in natural prose. Avoid boilerplate like 'User is viewing a screen capture' unless that detail is actually useful. Prefer descriptions like 'Reading an X thread about Cursor causing faster short-term coding but higher code complexity after month two' over generic browser descriptions. Preserve timestamp and meta unless a correction is obvious. Do not invent fields."
PROMPT_L2_GROUP="You group L1 activity traces into higher-level L2 clusters. Return strict JSON only with a top-level key 'events'. Emit only real multi-event groups; isolated events can be omitted. Each event must include: event_id, title, summary, clean_text, timestamp_start, timestamp_end, source_event_ids. source_event_ids must reference the input L1 event ids that belong to the group. Group by the underlying user activity or intent described in the L1 descriptions, not by superficial word overlap. title should name the shared activity. summary should briefly explain the common activity or thread that connects the events. clean_text can restate that shared activity in plain prose. Do not emit singleton passthrough items."
PROMPT_L3_USER_MODEL="You are an expert agent in behavior analysis and knowledge model construction. From the following processed events (L2), update the user's knowledge model. The knowledge model consists of a series of markdown files interconnected with [[wikilinks]] and classified with #tags. Analyze the events, identify topics, skills, projects, or areas of interest. If a file on a topic already exists, modify it to add new information or refine existing knowledge. If it is a new topic, create a new file. Current knowledge model context: {context}. Events to process: {events}."
PROMPT_L4_REFLECTION="You are a reflection and synthesis agent. You have analyzed a user's knowledge model for 24 hours. Your task is to consolidate information, identify behavioral patterns, detect knowledge gaps, and propose new connections or reflections. Review the following files from the user model and generate a consolidation report. You can refactor, merge, split files, or create a new summary file with your findings. Model files: {files}."
