{
  "audio": {
    "url": "https://generativelanguage.googleapis.com/v1beta/openai/chat/completions",
    "method": "POST",
    "timeout": 60,
    "headers": {
      "Authorization": "Bearer ${GEMINI_API_KEY}"
    },
    "format": "gemini",
    "body": {
      "model": "gemini-2.0-flash",
      "messages": [
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "Transcribe the attached audio."
            },
            {
              "type": "input_audio",
              "input_audio": {
                "data": "{{file.base64}}",
                "format": "{{file.audio_format}}"
              }
            }
          ]
        }
      ]
    }
  },
  "screen": {
    "url": "https://generativelanguage.googleapis.com/v1beta/openai/chat/completions",
    "method": "POST",
    "timeout": 60,
    "headers": {
      "Authorization": "Bearer ${GEMINI_API_KEY}"
    },
    "format": "gemini",
    "body": {
      "model": "gemini-2.0-flash",
      "messages": [
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "Describe or transcribe everything visible in the attached image."
            },
            {
              "type": "image_url",
              "image_url": {
                "url": "{{file.data_url}}"
              }
            }
          ]
        }
      ]
    }
  },
  "llm": {
    "url": "https://generativelanguage.googleapis.com/v1beta/openai/chat/completions",
    "method": "POST",
    "timeout": 60,
    "headers": {
      "Authorization": "Bearer ${GEMINI_API_KEY}"
    },
    "format": "gemini",
    "body": {
      "model": "gemini-2.0-flash"
    }
  }
}
