{
  "audio": {
    "url": "http://127.0.0.1:9092/v1/audio/transcriptions",
    "method": "POST",
    "timeout": 30,
    "headers": {},
    "format": "default"
  },
  "screen": {
    "url": "http://127.0.0.1:9093/ocr",
    "method": "POST",
    "timeout": 60,
    "headers": {},
    "format": "default"
  },
  "prompts": {
    "l1_clean": "You are cleaning a batch of raw vault records into structured memory items. Return strict JSON only with a top-level key 'events'. The output array must have one item per input event in the same order. Each item must include these keys only: l1_event_id, timestamp, title, clean_text, verbatim_quotes, meta. Rules: Preserve factual content. Keep verbatim_quotes as exact quoted substrings. Make title short and specific. Do not invent fields.",
    "l2_group": "You are grouping L1 events into higher-level L2 events. Return strict JSON only with a top-level key 'events'. Each event must include: event_id, title, summary, clean_text, timestamp_start, timestamp_end, source_indexes. source_indexes must reference the zero-based input array positions. Only emit events for real multi-event groups; do not emit singleton passthrough items.",
    "level_3_user_model": "You are an expert agent in behavior analysis and knowledge model construction. From the following processed events (L2), update the user's knowledge model. The knowledge model consists of a series of markdown files interconnected with [[wikilinks]] and classified with #tags. Analyze the events, identify topics, skills, projects, or areas of interest. If a file on a topic already exists, modify it to add new information or refine existing knowledge. If it is a new topic, create a new file. Current knowledge model context: {context}. Events to process: {events}.",
    "level_4_reflection": "You are a reflection and synthesis agent. You have analyzed a user's knowledge model for 24 hours. Your task is to consolidate information, identify behavioral patterns, detect knowledge gaps, and propose new connections or reflections. Review the following files from the user model and generate a consolidation report. You can refactor, merge, split files, or create a new summary file with your findings. Model files: {files}."
  },
  "llm_service": {
    "url": "http://localhost:8008/v1/chat/completions"
  }
}
