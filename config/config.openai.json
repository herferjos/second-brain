{
  "audio": {
    "url": "https://api.openai.com/v1/audio/transcriptions",
    "method": "POST",
    "timeout": 60,
    "headers": {
      "Authorization": "Bearer ${OPENAI_API_KEY}"
    },
    "format": "openai",
    "body": {
      "model": "whisper-1",
      "language": "en",
      "prompt": "Transcribe the attached audio."
    }
  },
  "screen": {
    "url": "https://api.openai.com/v1/chat/completions",
    "method": "POST",
    "timeout": 60,
    "headers": {
      "Authorization": "Bearer ${OPENAI_API_KEY}"
    },
    "format": "openai",
    "body": {
      "model": "gpt-4o-mini",
      "messages": [
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "Describe or transcribe everything visible in the attached image."
            },
            {
              "type": "image_url",
              "image_url": {
                "url": "{{file.data_url}}"
              }
            }
          ]
        }
      ]
    }
  },
  "llm": {
    "url": "https://api.openai.com/v1/chat/completions",
    "method": "POST",
    "timeout": 60,
    "headers": {
      "Authorization": "Bearer ${OPENAI_API_KEY}"
    },
    "format": "openai",
    "body": {
      "model": "gpt-4o-mini"
    }
  }
}