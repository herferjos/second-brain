# Llama.cpp — OpenAI-compatible chat completion API
# Copy to .env and adjust if needed.

# Required model source settings.
LLAMA_CPP_MODEL_ID=unsloth/Qwen3.5-2B-GGUF
LLAMA_CPP_QUANTIZATION=Q4_K_M

# Optional runtime settings.
LLAMA_CPP_MODEL_DIR=./models
LLAMA_CPP_CTX=4096
LLAMA_CPP_N_GPU_LAYERS=0
LLAMA_CPP_THREADS=0
LLAMA_CPP_N_BATCH=512
LLAMA_CPP_SEED=42
LLAMA_CPP_TEMPERATURE=0.2
LLAMA_CPP_HOST=127.0.0.1
LLAMA_CPP_PORT=9100
LLAMA_CPP_LOG_LEVEL=info
