# Mac ASR — transcription API
# Copy to .env and adjust if needed.

MAC_ASR_HOST=127.0.0.1
MAC_ASR_PORT=9092
MAC_ASR_LOCALE=auto
MAC_ASR_DEFAULT_LOCALE=es
MAC_ASR_TRANSCRIPTION_TIMEOUT_S=30
MAC_ASR_PROMPT_PERMISSION=true
MAC_ASR_LOG_LEVEL=INFO
MAC_ASR_DETECT_MODEL=tiny
MAC_ASR_DETECT_DEVICE=cpu
MAC_ASR_DETECT_COMPUTE_TYPE=int8
MAC_ASR_DETECT_DISCARD_MIN_PROB=0.5
MAC_ASR_DETECT_DEFAULT_MIN_PROB=0.7
